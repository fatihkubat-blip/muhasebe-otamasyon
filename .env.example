# Extension metadata
MODULE_SLUG=muhasebe-otamasyon
MODULE_VERSION=1.1.0
CONTRACT_VERSION=2026.04
DATABASE_BACKEND=sqlite
DATABASE_MODE=embedded

# Security
SECRET_KEY=change-me

