# ── Ortam ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=true

# ── Veritabanı ─────────────────────────────────────────────────────────────
# Geliştirme (SQLite):
DATABASE_URL=sqlite:///./data/muhasebe.db

# Üretim (SQL Server — ODBC Driver 18 kurulu olmalı):
# DATABASE_URL=mssql+pyodbc://sa:SIFRE@localhost:1433/muhasebe?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_ECHO=false

# ── Güvenlik ───────────────────────────────────────────────────────────────
SECRET_KEY=BURAYA_EN_AZ_32_KARAKTER_GUVENLI_ANAHTAR_YAZIN
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
BCRYPT_ROUNDS=12

# ── Sayfalama ──────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=1000

# ── e-Fatura / GİB ─────────────────────────────────────────────────────────
GIB_USE_PROD=false
GIB_API_USERNAME=
GIB_API_PASSWORD=

# ── E-posta ────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
